---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import type { CardData } from "@/types/card";

interface Props {
  title: string;
  description?: string;
  card: CardData;
  jsonLd?: object;
}

const { title, description, card, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header />
  <main id="main-content" class="min-h-screen">
    <!-- Breadcrumb -->
    <nav class="mx-auto max-w-7xl px-4 py-4" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-text-secondary">
        <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
        <li class="text-text-tertiary">/</li>
        <li>
          <a
            href={`/${card.cardType === "credit" ? "credit-cards" : card.cardType === "debit" ? "debit-cards" : "prepaid-cards"}`}
            class="hover:text-gold transition-colors"
          >
            {card.cardType === "credit"
              ? "Credit Cards"
              : card.cardType === "debit"
                ? "Debit Cards"
                : "Prepaid Cards"}
          </a>
        </li>
        <li class="text-text-tertiary">/</li>
        <li class="text-text-primary font-medium">{card.name}</li>
      </ol>
    </nav>
    <slot />
  </main>
  <Footer />
</BaseLayout>
