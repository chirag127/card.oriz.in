---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updateDate?: string;
  author: string;
  category: string;
  tags: string[];
  featuredImage: string;
  jsonLd?: object;
}

const props = Astro.props;
---

<BaseLayout
  title={props.title}
  description={props.description}
  ogImage={props.featuredImage}
  jsonLd={props.jsonLd}
>
  <Header />
  <main id="main-content" class="min-h-screen">
    <article class="mx-auto max-w-3xl px-4 py-12">
      <!-- Blog Header -->
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-gold text-sm font-medium uppercase tracking-wider">
            {props.category}
          </span>
          <span class="text-text-tertiary">·</span>
          <time class="text-text-secondary text-sm" datetime={props.publishDate}>
            {new Date(props.publishDate).toLocaleDateString("en-IN", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })}
          </time>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
          {props.title}
        </h1>
        <p class="text-xl text-text-secondary leading-relaxed">
          {props.description}
        </p>
        <div class="flex items-center gap-3 mt-6 pt-6 border-t border-border-default">
          <div class="w-10 h-10 rounded-full bg-bg-tertiary flex items-center justify-center text-gold font-bold">
            {props.author[0]}
          </div>
          <div>
            <p class="text-sm font-medium">{props.author}</p>
            <p class="text-xs text-text-tertiary">card.oriz.in</p>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert max-w-none">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
