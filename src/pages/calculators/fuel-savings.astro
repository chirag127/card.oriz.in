---
import PageLayout from "@/layouts/PageLayout.astro";
import FuelSavingsCalculator from "@/components/calculators/FuelSavingsCalculator";
import { ALL_CARDS } from "@/data/index";
---

<PageLayout
  title="Fuel Savings Calculator"
  description="Calculate how much you can save on fuel surcharges with the right credit card. Compare top fuel cards ranked by annual savings."
>
  <section class="py-12 lg:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h1 class="font-display text-3xl sm:text-4xl font-bold text-text-primary">
          Fuel <span class="text-gold">Savings Calculator</span>
        </h1>
        <p class="mt-4 text-text-secondary max-w-xl mx-auto">
          Enter your monthly fuel spend to see how much you can save with fuel surcharge waiver cards.
        </p>
      </div>

      <FuelSavingsCalculator client:visible allCards={ALL_CARDS} />

      <div class="mt-10 max-w-2xl mx-auto">
        <div class="rounded-2xl bg-bg-secondary/50 border border-border-default p-6">
          <h3 class="font-semibold text-text-primary mb-3">How fuel surcharge savings work</h3>
          <ul class="space-y-2 text-sm text-text-secondary">
            <li class="flex items-start gap-2">
              <span class="text-gold mt-0.5">•</span>
              Most fuel stations charge a 2.5% surcharge on card payments.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-0.5">•</span>
              Fuel cards waive part or all of this surcharge, saving you money on every fill-up.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-gold mt-0.5">•</span>
              Each card has a maximum waiver per billing cycle — check the card details for exact terms.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
