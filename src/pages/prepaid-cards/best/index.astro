---
import PageLayout from "@/layouts/PageLayout.astro";
import CardThumbnail from "@/components/cards/CardThumbnail.tsx";
import { PREPAID_CARDS } from "@/data/index";
import { getCardUrl } from "@/lib/utils";
import { generateItemListJsonLd } from "@/lib/seo";

const title = "Best Prepaid Cards India 2026 | card.oriz.in";
const description = `Browse ${PREPAID_CARDS.length} prepaid cards in India. Compare features, fees, and top-up options from banks and fintechs.`;

const jsonLd = generateItemListJsonLd(
  "Best Prepaid Cards in India",
  PREPAID_CARDS.map((card) => ({
    name: card.name,
    url: `https://card.oriz.in${getCardUrl(card)}`,
  }))
);
---

<PageLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="border-b border-border-default bg-bg-secondary/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <nav class="mb-6 text-sm text-text-tertiary" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
          <li class="text-text-tertiary">/</li>
          <li><a href="/prepaid-cards" class="hover:text-gold transition-colors">Prepaid Cards</a></li>
          <li class="text-text-tertiary">/</li>
          <li class="text-text-primary font-medium">Best Of</li>
        </ol>
      </nav>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-text-primary">
        Best Prepaid Cards
      </h1>
      <p class="mt-2 text-text-secondary max-w-2xl">
        Prepaid cards let you spend only what you load — no credit check, no bank account linking required. Ideal for budgeting, gifting, and controlled spending.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {PREPAID_CARDS.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {PREPAID_CARDS.map((card) => (
            <CardThumbnail card={card} showCompare={false} client:load />
          ))}
        </div>
      ) : (
        <p class="text-text-secondary">No prepaid cards found in our database.</p>
      )}
    </div>
  </section>
</PageLayout>
