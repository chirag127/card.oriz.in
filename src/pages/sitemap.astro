---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import { ALL_CARDS } from "@/data/index";
import { ALL_BANKS } from "@/data/banks-index";

const blogPosts = await getCollection("blog");
const glossaryTerms = await getCollection("glossary");

const sortedBlog = blogPosts.sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime()
);

const sortedGlossary = glossaryTerms.sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<PageLayout
  title="Sitemap"
  description="Complete sitemap of card.oriz.in — find every page on our website."
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-text-primary">
        Sitemap
      </h1>
      <p class="mt-4 text-lg text-text-secondary">
        A complete overview of every page on card.oriz.in.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      <!-- Main Pages -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Main</h2>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-text-secondary hover:text-gold transition-colors">Home</a></li>
          <li><a href="/credit-cards" class="text-sm text-text-secondary hover:text-gold transition-colors">Credit Cards</a></li>
          <li><a href="/debit-cards" class="text-sm text-text-secondary hover:text-gold transition-colors">Debit Cards</a></li>
          <li><a href="/card-genie" class="text-sm text-text-secondary hover:text-gold transition-colors">Card Genie (AI)</a></li>
          <li><a href="/compare" class="text-sm text-text-secondary hover:text-gold transition-colors">Compare Cards</a></li>
        </ul>
      </section>

      <!-- Best Cards -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Best Cards</h2>
        <ul class="space-y-2">
          <li><a href="/credit-cards/best/cashback" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Cashback</a></li>
          <li><a href="/credit-cards/best/travel" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Travel</a></li>
          <li><a href="/credit-cards/best/rewards" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Rewards</a></li>
          <li><a href="/credit-cards/best/fuel" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Fuel</a></li>
          <li><a href="/credit-cards/best/premium" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Premium</a></li>
          <li><a href="/credit-cards/best/no-annual-fee" class="text-sm text-text-secondary hover:text-gold transition-colors">No Annual Fee</a></li>
        </ul>
      </section>

      <!-- Calculators -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Calculators</h2>
        <ul class="space-y-2">
          <li><a href="/calculators/credit-card-interest" class="text-sm text-text-secondary hover:text-gold transition-colors">Interest Calculator</a></li>
          <li><a href="/calculators/rewards-value" class="text-sm text-text-secondary hover:text-gold transition-colors">Rewards Calculator</a></li>
          <li><a href="/calculators/fuel-savings" class="text-sm text-text-secondary hover:text-gold transition-colors">Fuel Savings</a></li>
        </ul>
      </section>

      <!-- Issuers -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Card Issuers</h2>
        <ul class="space-y-2">
          {ALL_BANKS.map((bank) => (
            <li>
              <a
                href={`/issuers/${bank.id}`}
                class="text-sm text-text-secondary hover:text-gold transition-colors"
              >
                {bank.shortName}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Blog -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Blog</h2>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-text-secondary hover:text-gold transition-colors">All Posts</a></li>
          {sortedBlog.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="text-sm text-text-secondary hover:text-gold transition-colors"
              >
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Glossary -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Glossary</h2>
        <ul class="space-y-2">
          <li><a href="/glossary" class="text-sm text-text-secondary hover:text-gold transition-colors">All Terms</a></li>
          {sortedGlossary.map((entry) => (
            <li>
              <a
                href={`/glossary/${entry.id}`}
                class="text-sm text-text-secondary hover:text-gold transition-colors"
              >
                {entry.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Info Pages -->
      <section>
        <h2 class="font-display text-lg font-bold text-gold mb-4">Information</h2>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-text-secondary hover:text-gold transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm text-text-secondary hover:text-gold transition-colors">Contact</a></li>
          <li><a href="/privacy-policy" class="text-sm text-text-secondary hover:text-gold transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="text-sm text-text-secondary hover:text-gold transition-colors">Terms of Service</a></li>
          <li><a href="/credit-score" class="text-sm text-text-secondary hover:text-gold transition-colors">Check Credit Score</a></li>
          <li><a href="/application-status" class="text-sm text-text-secondary hover:text-gold transition-colors">Application Status</a></li>
        </ul>
      </section>
    </div>
  </section>
</PageLayout>
