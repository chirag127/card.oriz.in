---
import PageLayout from "@/layouts/PageLayout.astro";
import CardThumbnail from "@/components/cards/CardThumbnail.tsx";
import { getBestCards } from "@/data/index";
import { getCardUrl } from "@/lib/utils";
import { generateItemListJsonLd } from "@/lib/seo";

const cards = getBestCards("premium", 10);

const title = "Best Premium Credit Cards India 2026 | card.oriz.in";
const description = "Most exclusive credit cards in India with luxury benefits, concierge services, golf privileges, and world-class travel perks.";

const jsonLd = generateItemListJsonLd(
  "Best Premium Credit Cards",
  cards.map((card) => ({
    name: card.name,
    url: `https://card.oriz.in${getCardUrl(card)}`,
  }))
);
---

<PageLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="border-b border-border-default bg-bg-secondary/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <nav class="mb-6 text-sm text-text-tertiary" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
          <li class="text-text-tertiary">/</li>
          <li><a href="/credit-cards" class="hover:text-gold transition-colors">Credit Cards</a></li>
          <li class="text-text-tertiary">/</li>
          <li><a href="/credit-cards/best" class="hover:text-gold transition-colors">Best Of</a></li>
          <li class="text-text-tertiary">/</li>
          <li class="text-text-primary font-medium">Premium</li>
        </ol>
      </nav>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-text-primary">
        Best Premium Credit Cards
      </h1>
      <p class="mt-2 text-text-secondary max-w-2xl">
        The most exclusive cards for high-net-worth individuals. Enjoy unlimited lounge access, personal concierge, golf rounds, luxury hotel upgrades, and bespoke travel privileges.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {cards.map((card) => (
          <CardThumbnail card={card} showCompare={false} client:load />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
