---
import PageLayout from "@/layouts/PageLayout.astro";

const title = "Best Credit Cards in India 2026 by Category | card.oriz.in";
const description = "Find the best credit cards in India for cashback, travel, rewards, fuel, premium benefits, and no annual fee. Curated rankings updated regularly.";

const categories = [
  { label: "Best Cashback Cards", href: "/credit-cards/best/cashback", icon: "CB", description: "Cards that give you money back on every purchase" },
  { label: "Best Travel Cards", href: "/credit-cards/best/travel", icon: "TR", description: "Lounge access, travel insurance, and airline rewards" },
  { label: "Best Rewards Cards", href: "/credit-cards/best/rewards", icon: "RW", description: "Earn points on every spend with great redemption options" },
  { label: "Best Fuel Cards", href: "/credit-cards/best/fuel", icon: "FU", description: "Fuel surcharge waivers and petrol pump rewards" },
  { label: "Best Premium Cards", href: "/credit-cards/best/premium", icon: "PR", description: "Luxury benefits, concierge, and exclusive privileges" },
  { label: "Best No Annual Fee", href: "/credit-cards/best/no-annual-fee", icon: "0", description: "Great benefits without any annual charges" },
];
---

<PageLayout title={title} description={description}>
  <section class="border-b border-border-default bg-bg-secondary/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <nav class="mb-6 text-sm text-text-tertiary" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
          <li class="text-text-tertiary">/</li>
          <li><a href="/credit-cards" class="hover:text-gold transition-colors">Credit Cards</a></li>
          <li class="text-text-tertiary">/</li>
          <li class="text-text-primary font-medium">Best Of</li>
        </ol>
      </nav>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-text-primary">
        Best Credit Cards by Category
      </h1>
      <p class="mt-2 text-text-secondary max-w-2xl">
        Our curated picks for the best credit cards in every spending category. Updated regularly based on fees, rewards, and real-world value.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="group p-6 rounded-xl bg-bg-secondary border border-border-default hover:border-gold/30 hover:shadow-lg hover:shadow-black/20 transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-4">
              <span class="text-sm font-bold text-gold">{cat.icon}</span>
            </div>
            <h2 class="font-display text-lg font-semibold text-text-primary group-hover:text-gold transition-colors">
              {cat.label}
            </h2>
            <p class="mt-2 text-sm text-text-secondary">{cat.description}</p>
            <span class="mt-4 inline-block text-sm text-gold">View cards →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
