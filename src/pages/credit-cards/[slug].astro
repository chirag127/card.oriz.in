---
import CardLayout from "@/layouts/CardLayout.astro";
import CardNetworkBadge from "@/components/cards/CardNetworkBadge.tsx";
import ApplyNowButton from "@/components/cards/ApplyNowButton.tsx";
import CardThumbnail from "@/components/cards/CardThumbnail.tsx";
import {
  CardValueChart,
  CardBenefitsPieChart,
  CardLimitsChart,
  CardRadarChart,
  CardChargesBreakdownChart,
} from "@/components/cards/CardCharts.tsx";
import { CREDIT_CARDS } from "@/data/index";
import { formatINR, formatINRFull } from "@/lib/formatters";
import { getAnnualFee, getJoiningFee } from "@/lib/utils";
import { generateCardJsonLd } from "@/lib/seo";
import type { CardData } from "@/types/card";

export function getStaticPaths() {
  return CREDIT_CARDS.map((card) => ({
    params: { slug: card.id },
    props: { card },
  }));
}

interface Props {
  card: CardData;
}

const { card } = Astro.props;
const annualFee = getAnnualFee(card);
const joiningFee = getJoiningFee(card);
const jsonLd = generateCardJsonLd(card);

const title = `${card.name} - Fees, Benefits & Rewards | card.oriz.in`;
const description = card.tagline;

const relatedCards = CREDIT_CARDS.filter(
  (c) => c.bankCode === card.bankCode && c.id !== card.id
).slice(0, 4);

const benefitsByCategory = card.benefits.reduce(
  (acc, benefit) => {
    const cat = benefit.category;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(benefit);
    return acc;
  },
  {} as Record<string, typeof card.benefits>
);

const categoryLabels: Record<string, string> = {
  lounge: "Airport Lounge Access",
  insurance: "Insurance Coverage",
  ott: "OTT & Streaming",
  shopping: "Shopping Benefits",
  travel: "Travel Benefits",
  food: "Food & Dining",
  health: "Health & Wellness",
  entertainment: "Entertainment",
  cashback: "Cashback Benefits",
  fuel: "Fuel Benefits",
  rewards: "Reward Points",
  concierge: "Concierge Services",
  education: "Education Benefits",
  utility: "Utility Payments",
  golf: "Golf Privileges",
  dining: "Dining Benefits",
  movies: "Movie Benefits",
  emi: "EMI Benefits",
  other: "Other Benefits",
};

function formatAmount(val: number): string {
  if (val >= 10000000) return `₹${(val / 10000000).toFixed(1)} Cr`;
  if (val >= 100000) return `₹${(val / 100000).toFixed(1)} L`;
  return formatINRFull(val);
}
---

<CardLayout title={title} description={description} card={card} jsonLd={jsonLd}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <!-- Breadcrumb -->
    <nav class="py-4 text-sm text-text-tertiary" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
        <li>/</li>
        <li><a href="/credit-cards" class="hover:text-gold transition-colors">Credit Cards</a></li>
        <li>/</li>
        <li class="text-text-primary font-medium">{card.name}</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="mt-4 rounded-2xl border border-border-default bg-bg-secondary overflow-hidden">
      <div class="grid lg:grid-cols-2 gap-0">
        <!-- Card Visual -->
        <div
          class="relative aspect-[1.586/1] lg:aspect-auto flex items-center justify-center"
          style={`background: linear-gradient(135deg, ${card.gradientColors[0]}, ${card.gradientColors[1]});`}
        >
          <div class="text-center">
            <span class="text-white/90 font-display text-2xl font-bold drop-shadow-lg">{card.bank}</span>
            <p class="text-white/60 text-sm mt-2">{card.tier} · {card.variant}</p>
          </div>
        </div>
        <!-- Card Info -->
        <div class="p-6 lg:p-8 flex flex-col justify-center">
          <div class="flex items-start gap-3 flex-wrap">
            <CardNetworkBadge network={card.network} size="md" client:load />
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-bg-tertiary text-text-secondary">
              {card.tier}
            </span>
            <span class="px-3 py-1 text-xs font-medium rounded-full bg-bg-tertiary text-text-secondary capitalize">
              {card.cardType}
            </span>
          </div>
          <h1 class="mt-4 font-display text-2xl sm:text-3xl font-bold text-text-primary">
            {card.name}
          </h1>
          <p class="mt-1 text-sm text-text-tertiary">{card.bank}</p>
          <p class="mt-3 text-text-secondary leading-relaxed">{card.tagline}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <ApplyNowButton card={card} size="lg" client:load />
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Stats -->
    <section class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="rounded-xl border border-border-default bg-bg-secondary p-5 text-center">
        <div class="text-xs text-text-tertiary uppercase tracking-wider">Annual Fee</div>
        <div class="mt-1 font-display text-xl font-bold text-text-primary">
          {annualFee === 0 ? "Free" : formatINRFull(annualFee)}
        </div>
      </div>
      <div class="rounded-xl border border-border-default bg-bg-secondary p-5 text-center">
        <div class="text-xs text-text-tertiary uppercase tracking-wider">Joining Fee</div>
        <div class="mt-1 font-display text-xl font-bold text-text-primary">
          {joiningFee === 0 ? "Free" : formatINRFull(joiningFee)}
        </div>
      </div>
      <div class="rounded-xl border border-border-default bg-bg-secondary p-5 text-center">
        <div class="text-xs text-text-tertiary uppercase tracking-wider">Reward Rate</div>
        <div class="mt-1 font-display text-xl font-bold text-gold">
          {card.rewardProgram?.effectiveCashbackPercent?.toFixed(1) ?? "—"}%
        </div>
      </div>
      <div class="rounded-xl border border-border-default bg-bg-secondary p-5 text-center">
        <div class="text-xs text-text-tertiary uppercase tracking-wider">Forex Markup</div>
        <div class="mt-1 font-display text-xl font-bold text-text-primary">
          {card.transactionCharges.currencyMarkupPercent}%
        </div>
      </div>
    </section>

    <!-- Value Metrics -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-6">Value Analysis</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <div class="text-sm text-text-tertiary">Annual Net Value</div>
          <div class="mt-1 font-display text-2xl font-bold text-gold">
            {formatINRFull(card.value.annualNetValue)}
          </div>
        </div>
        <div>
          <div class="text-sm text-text-tertiary">Total Annual Benefits</div>
          <div class="mt-1 font-display text-2xl font-bold text-emerald-card">
            {formatINRFull(card.value.totalAnnualBenefits)}
          </div>
        </div>
        <div>
          <div class="text-sm text-text-tertiary">Total Annual Charges</div>
          <div class="mt-1 font-display text-2xl font-bold text-rose-card">
            {formatINRFull(card.value.totalAnnualCharges)}
          </div>
        </div>
        <div>
          <div class="text-sm text-text-tertiary">ROI</div>
          <div class="mt-1 font-display text-2xl font-bold text-gold">
            {card.value.roiPercent}%
          </div>
        </div>
      </div>
      {card.feeWaivers.length > 0 && (
        <div class="mt-6 p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <div class="text-sm font-semibold text-text-primary mb-2">Fee Waiver Available</div>
          {card.feeWaivers.map((fw) => (
            <p class="text-sm text-text-secondary">
              {fw.description} — <span class="text-gold">{formatINRFull(fw.annualSpendRequired)} annual spend</span>
            </p>
          ))}
        </div>
      )}
    </section>

    <!-- Charts & Analytics -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-2">Card Analytics</h2>
      <p class="text-sm text-text-tertiary mb-6">Visual breakdown of value, benefits, and limits</p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-border-default bg-bg-primary p-4">
          <h3 class="text-sm font-semibold text-text-primary mb-2">Value Breakdown</h3>
          <CardValueChart card={card} client:load />
        </div>
        <div class="rounded-xl border border-border-default bg-bg-primary p-4">
          <h3 class="text-sm font-semibold text-text-primary mb-2">Benefits Distribution</h3>
          <CardBenefitsPieChart card={card} client:load />
        </div>
        <div class="rounded-xl border border-border-default bg-bg-primary p-4">
          <h3 class="text-sm font-semibold text-text-primary mb-2">Transaction Limits</h3>
          <CardLimitsChart card={card} client:load />
        </div>
        <div class="rounded-xl border border-border-default bg-bg-primary p-4">
          <h3 class="text-sm font-semibold text-text-primary mb-2">Card Scorecard</h3>
          <CardRadarChart card={card} client:load />
        </div>
        <div class="md:col-span-2 rounded-xl border border-border-default bg-bg-primary p-4">
          <h3 class="text-sm font-semibold text-text-primary mb-2">Charges Breakdown</h3>
          <CardChargesBreakdownChart card={card} client:load />
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-6">Benefits & Perks</h2>
      <div class="space-y-6">
        {Object.entries(benefitsByCategory).map(([category, benefits]) => (
          <details class="group rounded-xl border border-border-default bg-bg-primary">
            <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
              <div class="flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-gold"></span>
                <span class="font-semibold text-text-primary">
                  {categoryLabels[category] ?? category}
                </span>
                <span class="text-xs text-text-tertiary">({benefits.length})</span>
              </div>
              <svg class="w-5 h-5 text-text-tertiary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 pb-4 space-y-3">
              {benefits.map((b) => (
                <div class="flex items-start justify-between gap-4 p-3 rounded-lg bg-bg-secondary">
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-sm text-text-primary">{b.title}</div>
                    <div class="text-xs text-text-secondary mt-1">{b.description}</div>
                    {b.conditions.length > 0 && (
                      <ul class="mt-2 space-y-1">
                        {b.conditions.map((cond) => (
                          <li class="text-xs text-text-tertiary flex items-start gap-1.5">
                            <span class="text-gold mt-0.5">•</span>
                            {cond}
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-semibold text-gold">{b.valueStr}</div>
                    {b.annualValue > 0 && (
                      <div class="text-xs text-text-tertiary mt-0.5">
                        {formatINRFull(b.annualValue)}/yr
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Reward Program -->
    {card.rewardProgram && (
      <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
        <h2 class="font-display text-xl font-bold text-text-primary mb-6">Reward Program</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <div class="text-sm text-text-tertiary mb-1">Program</div>
            <div class="font-semibold text-text-primary">{card.rewardProgram.name}</div>
            <div class="text-sm text-text-secondary mt-2">{card.rewardProgram.earnRate}</div>
            <div class="text-sm text-text-secondary mt-1">
              Effective cashback: <span class="text-gold font-semibold">{card.rewardProgram.effectiveCashbackPercent.toFixed(2)}%</span>
            </div>
            <div class="text-xs text-text-tertiary mt-2">
              Points expire: {card.rewardProgram.pointsExpiry}
            </div>
          </div>
          <div>
            <div class="text-sm text-text-tertiary mb-2">Redemption Options</div>
            <ul class="space-y-2">
              {card.rewardProgram.redemptionOptions.map((opt) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="text-gold mt-0.5">→</span>
                  {opt}
                </li>
              ))}
            </ul>
          </div>
        </div>
        {card.rewardProgram.bonusCategories.length > 0 && (
          <div class="mt-6">
            <div class="text-sm text-text-tertiary mb-3">Bonus Categories</div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {card.rewardProgram.bonusCategories.map((bc) => (
                <div class="p-3 rounded-lg bg-bg-tertiary border border-border-default">
                  <div class="font-medium text-sm text-text-primary">{bc.category}</div>
                  <div class="text-xs text-gold mt-1">{bc.multiplier}x multiplier</div>
                  <div class="text-xs text-text-tertiary mt-1">{bc.description}</div>
                </div>
              ))}
            </div>
          </div>
        )}
        {card.milestoneBonuses.length > 0 && (
          <div class="mt-6">
            <div class="text-sm text-text-tertiary mb-3">Milestone Bonuses</div>
            <div class="space-y-3">
              {card.milestoneBonuses.map((mb) => (
                <div class="flex items-center justify-between p-3 rounded-lg bg-bg-tertiary border border-border-default">
                  <div>
                    <div class="text-sm font-medium text-text-primary">{mb.description}</div>
                    <div class="text-xs text-text-tertiary mt-1">
                      Spend {formatINRFull(mb.spendRequired)} {mb.spendPeriod.toLowerCase()}
                    </div>
                  </div>
                  <div class="text-sm font-semibold text-gold">{mb.rewardStr}</div>
                </div>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- Fees & Charges -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-6">Fees & Charges</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border-default">
              <th class="text-left py-3 px-4 text-text-tertiary font-medium">Charge</th>
              <th class="text-right py-3 px-4 text-text-tertiary font-medium">Amount</th>
            </tr>
          </thead>
          <tbody>
            {card.charges.map((charge) => (
              <tr class="border-b border-border-default/50">
                <td class="py-3 px-4 text-text-primary">{charge.label}</td>
                <td class="py-3 px-4 text-right text-text-primary font-medium">
                  {charge.amount === 0 ? (
                    <span class="text-emerald-card">Free</span>
                  ) : (
                    formatINRFull(charge.amount)
                  )}
                  {charge.note && (
                    <span class="block text-xs text-text-tertiary">{charge.note}</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-6 grid md:grid-cols-2 gap-6">
        <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <h3 class="font-semibold text-sm text-text-primary mb-3">Transaction Charges</h3>
          <dl class="space-y-2 text-sm">
            <div class="flex justify-between">
              <dt class="text-text-secondary">Forex Markup</dt>
              <dd class="text-text-primary font-medium">{card.transactionCharges.currencyMarkupPercent}%</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-text-secondary">Interest Rate (Monthly)</dt>
              <dd class="text-text-primary font-medium">{card.transactionCharges.interestRatePerMonth ?? "—"}%</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-text-secondary">Late Payment Fee</dt>
              <dd class="text-text-primary font-medium">
                {card.transactionCharges.latePaymentFee
                  ? formatINRFull(card.transactionCharges.latePaymentFee)
                  : "—"}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-text-secondary">Cash Advance Fee</dt>
              <dd class="text-text-primary font-medium">
                {card.transactionCharges.cashAdvanceFeePercent ?? "—"}%
              </dd>
            </div>
          </dl>
        </div>

        <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <h3 class="font-semibold text-sm text-text-primary mb-3">ATM Charges</h3>
          <dl class="space-y-2 text-sm">
            <div class="flex justify-between">
              <dt class="text-text-secondary">Own Bank Withdrawal</dt>
              <dd class="text-text-primary font-medium">
                {card.atmCharges.ownBankCharge === 0
                  ? "Free"
                  : formatINRFull(card.atmCharges.ownBankCharge)}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-text-secondary">Other Bank Withdrawal</dt>
              <dd class="text-text-primary font-medium">
                {card.atmCharges.otherBankCharge === 0
                  ? "Free"
                  : formatINRFull(card.atmCharges.otherBankCharge)}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-text-secondary">Intl. Withdrawal Fee</dt>
              <dd class="text-text-primary font-medium">
                {card.atmCharges.internationalWithdrawalPercent}% + {formatINRFull(card.atmCharges.internationalWithdrawalFee)}
              </dd>
            </div>
          </dl>
        </div>
      </div>

      {card.fuelSurcharge?.available && (
        <div class="mt-6 p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <h3 class="font-semibold text-sm text-text-primary mb-2">Fuel Surcharge Waiver</h3>
          <p class="text-sm text-text-secondary">
            {card.fuelSurcharge.waiverPercent}% waiver on transactions between {formatINRFull(card.fuelSurcharge.minTransactionAmount)} – {formatINRFull(card.fuelSurcharge.maxTransactionAmount)}. Max waiver: {formatINRFull(card.fuelSurcharge.maxWaiverPerCycle)}/cycle.
          </p>
        </div>
      )}
    </section>

    <!-- Eligibility -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-6">Eligibility</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-sm font-semibold text-text-primary mb-3">Requirements</h3>
          <dl class="space-y-3 text-sm">
            {card.eligibility.minSalary && (
              <div class="flex justify-between">
                <dt class="text-text-secondary">Min. Monthly Income</dt>
                <dd class="text-text-primary font-medium">{formatINRFull(card.eligibility.minSalary)}</dd>
              </div>
            )}
            {card.eligibility.minAnnualIncome && (
              <div class="flex justify-between">
                <dt class="text-text-secondary">Min. Annual Income</dt>
                <dd class="text-text-primary font-medium">{formatINRFull(card.eligibility.minAnnualIncome)}</dd>
              </div>
            )}
            {card.eligibility.minCreditScore && (
              <div class="flex justify-between">
                <dt class="text-text-secondary">Min. Credit Score</dt>
                <dd class="text-text-primary font-medium">{card.eligibility.minCreditScore}</dd>
              </div>
            )}
            {card.eligibility.minAge && card.eligibility.maxAge && (
              <div class="flex justify-between">
                <dt class="text-text-secondary">Age Range</dt>
                <dd class="text-text-primary font-medium">{card.eligibility.minAge} – {card.eligibility.maxAge} years</dd>
              </div>
            )}
            {card.eligibility.employmentType && (
              <div class="flex justify-between">
                <dt class="text-text-secondary">Employment</dt>
                <dd class="text-text-primary font-medium">{card.eligibility.employmentType.join(", ")}</dd>
              </div>
            )}
          </dl>
        </div>
        {card.eligibility.notes.length > 0 && (
          <div>
            <h3 class="text-sm font-semibold text-text-primary mb-3">Notes</h3>
            <ul class="space-y-2">
              {card.eligibility.notes.map((note) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <span class="text-gold mt-0.5">•</span>
                  {note}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        {card.eligibility.existingAccountRequired && (
          <span class="px-3 py-1 text-xs rounded-full bg-amber-card/20 text-amber-card border border-amber-card/30">
            Existing account required
          </span>
        )}
        {card.eligibility.invitationOnly && (
          <span class="px-3 py-1 text-xs rounded-full bg-rose-card/20 text-rose-card border border-rose-card/30">
            Invitation only
          </span>
        )}
      </div>
    </section>

    <!-- Insurance -->
    {card.insurance && (
      <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
        <h2 class="font-display text-xl font-bold text-text-primary mb-6">Insurance Coverage</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {card.insurance.accidentalDeathCover > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Accidental Death</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.accidentalDeathCover)}</div>
            </div>
          )}
          {card.insurance.permanentDisabilityCover > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Permanent Disability</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.permanentDisabilityCover)}</div>
            </div>
          )}
          {card.insurance.travelInsuranceCover && card.insurance.travelInsuranceCover > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Travel Insurance</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.travelInsuranceCover)}</div>
            </div>
          )}
          {card.insurance.lostCardLiability && card.insurance.lostCardLiability > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Lost Card Liability</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.lostCardLiability)}</div>
              {card.insurance.lostCardLiabilityWindow && (
                <div class="text-xs text-text-tertiary mt-1">Report within {card.insurance.lostCardLiabilityWindow}h</div>
              )}
            </div>
          )}
          {card.insurance.airAccidentCover && card.insurance.airAccidentCover > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Air Accident Cover</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.airAccidentCover)}</div>
            </div>
          )}
          {card.insurance.purchaseProtectionCover && card.insurance.purchaseProtectionCover > 0 && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary uppercase tracking-wider">Purchase Protection</div>
              <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatAmount(card.insurance.purchaseProtectionCover)}</div>
              {card.insurance.purchaseProtectionDays && (
                <div class="text-xs text-text-tertiary mt-1">{card.insurance.purchaseProtectionDays} days</div>
              )}
            </div>
          )}
        </div>
        {card.insurance.conditions.length > 0 && (
          <ul class="mt-4 space-y-1">
            {card.insurance.conditions.map((c) => (
              <li class="text-xs text-text-tertiary flex items-start gap-1.5">
                <span class="text-gold mt-0.5">•</span>
                {c}
              </li>
            ))}
          </ul>
        )}
      </section>
    )}

    <!-- Lounge Access -->
    {card.loungeAccess && (
      <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
        <h2 class="font-display text-xl font-bold text-text-primary mb-6">Airport Lounge Access</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
            <h3 class="font-semibold text-sm text-text-primary mb-3">Domestic</h3>
            <div class="font-display text-3xl font-bold text-gold">
              {card.loungeAccess.domestic.count}
              <span class="text-sm font-normal text-text-tertiary ml-1">visits/year</span>
            </div>
            <p class="text-xs text-text-tertiary mt-1">{card.loungeAccess.domestic.frequency}</p>
            {card.loungeAccess.domestic.valuePerVisit > 0 && (
              <p class="text-xs text-text-secondary mt-1">
                ~{formatINRFull(card.loungeAccess.domestic.valuePerVisit)}/visit
              </p>
            )}
          </div>
          <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
            <h3 class="font-semibold text-sm text-text-primary mb-3">International</h3>
            <div class="font-display text-3xl font-bold text-gold">
              {card.loungeAccess.international.count}
              <span class="text-sm font-normal text-text-tertiary ml-1">visits/year</span>
            </div>
            <p class="text-xs text-text-tertiary mt-1">{card.loungeAccess.international.frequency}</p>
            {card.loungeAccess.international.valuePerVisit > 0 && (
              <p class="text-xs text-text-secondary mt-1">
                ~{formatINRFull(card.loungeAccess.international.valuePerVisit)}/visit
              </p>
            )}
          </div>
        </div>
        {card.loungeAccess.programs.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {card.loungeAccess.programs.map((p) => (
              <span class="px-3 py-1 text-xs rounded-full bg-bg-tertiary text-text-secondary border border-border-default">
                {p}
              </span>
            ))}
          </div>
        )}
        {card.loungeAccess.conditions.length > 0 && (
          <ul class="mt-4 space-y-1">
            {card.loungeAccess.conditions.map((c) => (
              <li class="text-xs text-text-tertiary flex items-start gap-1.5">
                <span class="text-gold mt-0.5">•</span>
                {c}
              </li>
            ))}
          </ul>
        )}
      </section>
    )}

    <!-- Card Limits -->
    <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
      <h2 class="font-display text-xl font-bold text-text-primary mb-6">Transaction Limits</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <div class="text-xs text-text-tertiary uppercase tracking-wider">ATM Withdrawal / Day</div>
          <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatINRFull(card.limits.atmPerDay)}</div>
        </div>
        <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
          <div class="text-xs text-text-tertiary uppercase tracking-wider">POS & E-Commerce / Day</div>
          <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatINRFull(card.limits.posEcomPerDay)}</div>
        </div>
        {card.limits.contactlessPerTxn && (
          <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
            <div class="text-xs text-text-tertiary uppercase tracking-wider">Contactless / Txn</div>
            <div class="mt-1 font-display text-lg font-bold text-text-primary">{formatINRFull(card.limits.contactlessPerTxn)}</div>
          </div>
        )}
      </div>
    </section>

    <!-- Features -->
    {card.features.length > 0 && (
      <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
        <h2 class="font-display text-xl font-bold text-text-primary mb-4">Features</h2>
        <div class="flex flex-wrap gap-2">
          {card.features.map((f) => (
            <span class="px-3 py-1.5 text-sm rounded-lg bg-bg-tertiary text-text-secondary border border-border-default">
              {f}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- EMI Options -->
    {card.emiOptions?.available && (
      <section class="mt-8 rounded-2xl border border-border-default bg-bg-secondary p-6 lg:p-8">
        <h2 class="font-display text-xl font-bold text-text-primary mb-4">EMI Options</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
            <div class="text-xs text-text-tertiary">Min. Transaction</div>
            <div class="mt-1 font-semibold text-text-primary">{formatINRFull(card.emiOptions.minTransactionAmount)}</div>
          </div>
          {card.emiOptions.interestRatePerMonth && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary">Interest / Month</div>
              <div class="mt-1 font-semibold text-text-primary">{card.emiOptions.interestRatePerMonth}%</div>
            </div>
          )}
          <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
            <div class="text-xs text-text-tertiary">Tenure Options</div>
            <div class="mt-1 font-semibold text-text-primary">{card.emiOptions.tenureOptions.join(", ")} months</div>
          </div>
          {card.emiOptions.processingFeePercent && (
            <div class="p-4 rounded-xl bg-bg-tertiary border border-border-default">
              <div class="text-xs text-text-tertiary">Processing Fee</div>
              <div class="mt-1 font-semibold text-text-primary">{card.emiOptions.processingFeePercent}%</div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Apply CTA -->
    <section class="mt-8 rounded-2xl border border-border-default bg-gradient-to-br from-bg-secondary to-bg-tertiary p-6 lg:p-8 text-center">
      <h2 class="font-display text-2xl font-bold text-text-primary">Ready to Apply?</h2>
      <p class="mt-2 text-text-secondary max-w-md mx-auto">
        {card.description ? card.description.slice(0, 150) : card.tagline}...
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
        <ApplyNowButton card={card} size="lg" client:load />
      </div>
    </section>

    <!-- Related Cards -->
    {relatedCards.length > 0 && (
      <section class="mt-12">
        <h2 class="font-display text-xl font-bold text-text-primary mb-6">
          More from {card.bank}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedCards.map((c) => (
            <CardThumbnail card={c} showCompare={false} client:load />
          ))}
        </div>
      </section>
    )}
  </div>
</CardLayout>
