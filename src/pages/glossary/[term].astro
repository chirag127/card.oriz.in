---
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("glossary");
  return entries.map((entry) => ({
    params: { term: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allEntries = await getCollection("glossary");
const relatedEntries = allEntries.filter((e) =>
  entry.data.relatedTerms.includes(e.id)
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: entry.data.title,
  description: entry.data.description,
  url: `https://card.oriz.in/glossary/${entry.id}`,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "card.oriz.in Glossary",
    url: "https://card.oriz.in/glossary",
  },
};
---

<PageLayout
  title={`${entry.data.title} — Glossary`}
  description={entry.data.description}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <nav class="mb-8 text-sm text-text-tertiary">
      <a href="/glossary" class="hover:text-gold transition-colors">Glossary</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">{entry.data.title}</span>
    </nav>

    <header class="mb-10">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-text-primary leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-xl text-text-secondary leading-relaxed">
        {entry.data.description}
      </p>
    </header>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>

    {relatedEntries.length > 0 && (
      <section class="mt-16 pt-10 border-t border-border-default">
        <h2 class="font-display text-xl font-bold text-text-primary mb-6">
          Related Terms
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedEntries.map((related) => (
            <a
              href={`/glossary/${related.id}`}
              class="group p-4 rounded-xl bg-bg-secondary border border-border-default hover:border-gold/30 transition-all duration-200"
            >
              <h3 class="font-semibold text-text-primary group-hover:text-gold transition-colors">
                {related.data.title}
              </h3>
              <p class="mt-1 text-sm text-text-secondary line-clamp-2">
                {related.data.description}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-12">
      <a
        href="/glossary"
        class="inline-flex items-center text-sm text-gold hover:text-gold-2 transition-colors"
      >
        ← Back to Glossary
      </a>
    </div>
  </article>
</PageLayout>
