---
import { getCollection } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime()
);

function estimateReadTime(content: string): number {
  const words = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<PageLayout
  title="Blog"
  description="Expert guides, tips, and analysis on credit cards, debit cards, and personal finance in India."
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-text-primary">
        Blog
      </h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl">
        Expert guides, tips, and analysis to help you make smarter financial decisions with your cards.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => {
        const readTime = estimateReadTime(post.body ?? "");
        return (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col rounded-2xl bg-gradient-to-br from-bg-secondary to-bg-tertiary border border-border-default hover:border-gold/30 transition-all duration-200 overflow-hidden"
          >
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-gold text-xs font-medium uppercase tracking-wider">
                  {post.data.category}
                </span>
                <span class="text-text-tertiary text-xs">·</span>
                <time
                  class="text-text-tertiary text-xs"
                  datetime={post.data.publishDate}
                >
                  {new Date(post.data.publishDate).toLocaleDateString("en-IN", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })}
                </time>
              </div>
              <h2 class="text-xl font-display font-bold text-text-primary group-hover:text-gold transition-colors leading-snug mb-3">
                {post.data.title}
              </h2>
              <p class="text-sm text-text-secondary leading-relaxed flex-1">
                {post.data.description}
              </p>
              <div class="mt-6 pt-4 border-t border-border-default flex items-center justify-between">
                <span class="text-xs text-text-tertiary">
                  {readTime} min read
                </span>
                <span class="text-sm text-gold group-hover:text-gold-2 transition-colors">
                  Read more →
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</PageLayout>
