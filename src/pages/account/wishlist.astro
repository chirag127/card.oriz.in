---
import PageLayout from "@/layouts/PageLayout.astro";

const title = "My Wishlist | card.oriz.in";
const description = "View and manage your saved cards wishlist.";
---

<PageLayout title={title} description={description}>
  <section class="border-b border-border-default bg-bg-secondary/30">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
      <nav class="mb-6 text-sm text-text-tertiary" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
          <li class="text-text-tertiary">/</li>
          <li><a href="/account" class="hover:text-gold transition-colors">Account</a></li>
          <li class="text-text-tertiary">/</li>
          <li class="text-text-primary font-medium">Wishlist</li>
        </ol>
      </nav>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-text-primary">
        My Wishlist
      </h1>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-md px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-bg-tertiary flex items-center justify-center">
        <span class="text-2xl text-text-secondary">?</span>
      </div>
      <h2 class="font-display text-xl font-bold text-text-primary">
        Sign in to view your wishlist
      </h2>
      <p class="mt-3 text-text-secondary">
        Save cards you're interested in and compare them later. Your wishlist syncs across all your devices.
      </p>
      <a
        href="/credit-cards"
        class="mt-6 inline-block px-6 py-3 border border-gold/30 text-gold rounded-xl hover:bg-gold/10 transition-colors"
      >
        Browse Cards
      </a>
    </div>
  </section>
</PageLayout>
