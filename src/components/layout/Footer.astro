---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-default bg-bg-secondary mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1">
        <a href="/" class="font-display text-xl font-bold text-text-primary">
          card<span class="text-gold">.</span>oriz<span class="text-gold">.</span>in
        </a>
        <p class="mt-3 text-sm text-text-secondary leading-relaxed">
          India's most comprehensive card intelligence platform. Compare 300+ cards with AI-powered recommendations.
        </p>
        <p class="mt-4 text-xs text-text-tertiary">
          Data verified from official bank sources. Updated daily.
        </p>
      </div>

      <!-- Credit Cards -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary mb-4">Credit Cards</h3>
        <ul class="space-y-2">
          <li><a href="/credit-cards" class="text-sm text-text-secondary hover:text-gold transition-colors">All Credit Cards</a></li>
          <li><a href="/credit-cards/best/cashback" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Cashback</a></li>
          <li><a href="/credit-cards/best/travel" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Travel</a></li>
          <li><a href="/credit-cards/best/rewards" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Rewards</a></li>
          <li><a href="/credit-cards/best/fuel" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Fuel</a></li>
          <li><a href="/credit-cards/best/premium" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Premium</a></li>
          <li><a href="/credit-cards/best/no-annual-fee" class="text-sm text-text-secondary hover:text-gold transition-colors">No Annual Fee</a></li>
        </ul>
      </div>

      <!-- Debit & Prepaid -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary mb-4">Debit & Prepaid</h3>
        <ul class="space-y-2">
          <li><a href="/debit-cards" class="text-sm text-text-secondary hover:text-gold transition-colors">All Debit Cards</a></li>
          <li><a href="/debit-cards/best/cashback" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Cashback Debit</a></li>
          <li><a href="/debit-cards/best/international" class="text-sm text-text-secondary hover:text-gold transition-colors">Best International</a></li>
          <li><a href="/debit-cards/best/premium" class="text-sm text-text-secondary hover:text-gold transition-colors">Best Premium Debit</a></li>
          <li><a href="/prepaid-cards" class="text-sm text-text-secondary hover:text-gold transition-colors">All Prepaid Cards</a></li>
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary mb-4">Tools</h3>
        <ul class="space-y-2">
          <li><a href="/card-genie" class="text-sm text-text-secondary hover:text-gold transition-colors">Card Genie (AI)</a></li>
          <li><a href="/compare" class="text-sm text-text-secondary hover:text-gold transition-colors">Compare Cards</a></li>
          <li><a href="/calculators/credit-card-interest" class="text-sm text-text-secondary hover:text-gold transition-colors">Interest Calculator</a></li>
          <li><a href="/calculators/rewards-value" class="text-sm text-text-secondary hover:text-gold transition-colors">Rewards Calculator</a></li>
          <li><a href="/calculators/fuel-savings" class="text-sm text-text-secondary hover:text-gold transition-colors">Fuel Savings</a></li>
          <li><a href="/credit-score" class="text-sm text-text-secondary hover:text-gold transition-colors">Check Credit Score</a></li>
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h3 class="text-sm font-semibold text-text-primary mb-4">Learn</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-text-secondary hover:text-gold transition-colors">Blog</a></li>
          <li><a href="/glossary" class="text-sm text-text-secondary hover:text-gold transition-colors">Card Glossary</a></li>
          <li><a href="/issuers" class="text-sm text-text-secondary hover:text-gold transition-colors">Card Issuers</a></li>
          <li><a href="/application-status" class="text-sm text-text-secondary hover:text-gold transition-colors">Application Status</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border-default flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-text-tertiary">
        &copy; {currentYear} card.oriz.in. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy-policy" class="text-sm text-text-tertiary hover:text-gold transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="text-sm text-text-tertiary hover:text-gold transition-colors">Terms of Service</a>
        <a href="/about" class="text-sm text-text-tertiary hover:text-gold transition-colors">About</a>
        <a href="/contact" class="text-sm text-text-tertiary hover:text-gold transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
